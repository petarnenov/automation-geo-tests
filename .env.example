# GeoWealth E2E — environment variables template
#
# Copy this file to .env.local at the workspace root and fill in your real
# values from the secret store. .env.local is gitignored.
#
# This file is the source-of-truth schema for what env vars the framework
# (and the legacy POC) read. Phase 0 Step 0.C will inventory the actual
# references in packages/legacy-poc/ and grow this file accordingly.

# ---------------------------------------------------------------------------
# Target environment selection
# ---------------------------------------------------------------------------

# Which GeoWealth environment to test against. Allowed: qa1..qa10, qatrd.
# The walking skeleton (Step 0.F) and the POC default to qa2 (D-23).
TEST_ENV=qa2

# ---------------------------------------------------------------------------
# Application credentials (Phase 0 Step 0.D will rotate these)
# ---------------------------------------------------------------------------

# Seed Platform One admin (firm 106 advisor pattern: timN with shared password).
TIM1_USERNAME=
TIM1_PASSWORD=

# ---------------------------------------------------------------------------
# TestRail integration
# ---------------------------------------------------------------------------

# TestRail API host (defaults to https://testrail.geowealth.com when unset).
# TESTRAIL_URL=

# TestRail API user — typically the same email used to log in to TestRail.
TESTRAIL_USER=

# Prefer API key (https://testrail.geowealth.com/index.php?/account/api-keys).
# Password is supported as a fallback if API key is not configured.
TESTRAIL_API_KEY=
# TESTRAIL_PASSWORD=

# Disable result posting locally with: TESTRAIL_REPORT_RESULTS=0
# TESTRAIL_REPORT_RESULTS=1

# Optionally also post test.skip / test.fixme as TestRail Blocked.
# TESTRAIL_REPORT_SKIPPED=0

# ---------------------------------------------------------------------------
# Phase 1 additions (placeholders — populated when CI lands)
# ---------------------------------------------------------------------------

# SKIP_PREFLIGHT=1   # On-call manual override for the nightly pre-flight (D-23 / Section 5.9)
# TESTRAIL_REPORTING=on   # Enable framework's TS reporter (Phase 1 deliverable)
