{
  "name": "geowealth-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "GeoWealth E2E test framework — monorepo root. Hosts framework, tooling, legacy POC, and per-team test packages.",
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p packages/framework/tsconfig.json --noEmit && tsc -p packages/tooling/tsconfig.json --noEmit",
    "scaffold:team": "tsx packages/tooling/src/scaffold-team.ts",
    "scaffold:doctor": "tsx packages/tooling/src/scaffold-doctor.ts",
    "_comment_legacy_": "Legacy POC scripts invoke playwright directly with --config (NOT via nested 'npm run --workspace='). Reason: nested 'npm run' chains drop additional CLI args (e.g. '-- --list') silently, which caused two accidental full-suite runs against TestRail Run 175 during Step 0.B/C verification. Direct playwright invocation forwards args correctly.",
    "test": "playwright test --config packages/legacy-poc/playwright.config.js",
    "test:legacy": "playwright test --config packages/legacy-poc/playwright.config.js",
    "test:legacy:pepi": "playwright test --config packages/legacy-poc/playwright.config.js --grep @pepi",
    "test:legacy:pepi:dry": "TESTRAIL_REPORT_RESULTS=0 playwright test --config packages/legacy-poc/playwright.config.js --grep @pepi",
    "discover:legacy:pepi": "TESTRAIL_REPORT_RESULTS=0 playwright test --config packages/legacy-poc/playwright.config.js --grep @pepi --list",
    "report:legacy": "playwright show-report packages/legacy-poc/playwright-report"
  },
  "devDependencies": {
    "@eslint/js": "~10.0.1",
    "@playwright/test": "~1.59.1",
    "@types/node": "~20.0.0",
    "@typescript-eslint/eslint-plugin": "~8.58.0",
    "@typescript-eslint/parser": "~8.58.0",
    "dotenv-flow": "~4.1.0",
    "eslint": "~10.2.0",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-playwright": "~2.10.1",
    "globals": "~17.4.0",
    "prettier": "~3.8.1",
    "tsx": "~4.19.0",
    "typescript": "~5.5.0",
    "zod": "~3.23.0"
  }
}
