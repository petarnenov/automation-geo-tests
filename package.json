{
  "name": "automation-geo-tests",
  "version": "0.1.0",
  "private": true,
  "description": "GeoWealth Playwright automation, scoped to TestRail Run 175 cases tagged @pepi",
  "scripts": {
    "test": "playwright test",
    "test:pepi": "playwright test --grep @pepi",
    "test:pepi:dry": "TESTRAIL_REPORT_RESULTS=0 playwright test --grep @pepi",
    "report": "playwright show-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.47.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1"
  }
}
