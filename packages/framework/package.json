{
  "name": "@geowealth/e2e-framework",
  "version": "0.1.0",
  "private": true,
  "description": "GeoWealth E2E shared framework — Page Objects, Component classes, fixtures, API client, factories, types, and the TestRail reporter. The single source of reusable test infrastructure for every team package.",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config/index.ts",
    "./fixtures": "./src/fixtures/index.ts",
    "./fixtures/globalSetup": "./src/fixtures/globalSetup.ts",
    "./fixtures/workerFirm": "./src/fixtures/workerFirm.fixture.ts",
    "./fixtures/api": "./src/fixtures/api.fixture.ts",
    "./fixtures/pages": "./src/fixtures/pages.fixture.ts",
    "./pages": "./src/pages/index.ts",
    "./components": "./src/components/index.ts",
    "./api": "./src/api/index.ts",
    "./api/client": "./src/api/client.ts",
    "./api/qa/DummyFirmApi": "./src/api/qa/DummyFirmApi.ts",
    "./data": "./src/data/index.ts",
    "./data/constants": "./src/data/constants/index.ts",
    "./reporters": "./src/reporters/index.ts",
    "./reporters/testrail-reporter": "./src/reporters/testrail-reporter.ts",
    "./reporters/run-summary-reporter": "./src/reporters/run-summary-reporter.ts",
    "./helpers": "./src/helpers/index.ts",
    "./types": "./src/types/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=24"
  }
}
